AWS_REGION=eu-west-1
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lms?sslmode=disable
DB_CONN_MAX_LIFETIME=5m
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
FRONTEND_URL=http://localhost:3000
GO_ENV=development
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
PORT=8080
REDIS_URL=redis://localhost:6379
S3_BUCKET_NAME=your-bucket-name
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com

# SuperAdmin Seed Configuration (created automatically on first startup)
# Leave commented to use defaults or uncomment to customize
# SUPERADMIN_EMAIL=admin@example.com
# SUPERADMIN_PASSWORD=ChangeMe123!
# SUPERADMIN_FIRST_NAME=Super
# SUPERADMIN_LAST_NAME=Admin
